<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModel="clr-namespace:ConstellaTTS.Core.ViewModels"
        xmlns:regions="clr-namespace:ConstellaTTS.Core.UI.Regions;assembly=ConstellaTTS.Core"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
        x:Class="ConstellaTTS.Core.Windows.MainWindow"
        Title="ConstellaTTS"
        MinWidth="800" MinHeight="500"
        Classes="g-bg-base"
        x:DataType="viewModel:MainWindowViewModel"
        Background="{StaticResource BgBase}"
        WindowDecorations="None"
        ExtendClientAreaToDecorationsHint="False"
        xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
        xmlns:ia="clr-namespace:Avalonia.Xaml.Interactions.Core;assembly=Avalonia.Xaml.Interactions">

    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="PointerMoved">
            <InvokeCommandAction Command="{Binding PointerCommand}" PassEventArgsToCommand="True"/>
        </EventTriggerBehavior>
    </Interaction.Behaviors>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Row 0: Title Bar -->
        <Border Grid.Row="0"
                Background="{StaticResource BgRibbon}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Height="32"
                IsHitTestVisible="True">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Border Grid.Column="0" Width="8" IsHitTestVisible="False" />
                <Panel Grid.Column="1">
                    <Border x:Name="TitleBarDragArea" Background="Transparent" IsHitTestVisible="True" />
                    <Menu Background="Transparent"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          FontSize="12"
                          Margin="0,4">
                        <MenuItem Header="File" />
                        <MenuItem Header="Edit" />
                        <MenuItem Header="View" />
                        <MenuItem Header="Help" />
                    </Menu>
                </Panel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0" VerticalAlignment="Stretch">
                    <Button x:Name="MinimizeBtn" Width="40" Height="32" Padding="0"
                            VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource FgSecondary}">
                        <TextBlock Text="&#x2014;" FontSize="10" VerticalAlignment="Center" />
                    </Button>
                    <Button x:Name="MaximizeBtn" Width="40" Height="32" Padding="0"
                            VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource FgSecondary}">
                        <TextBlock Text="&#x25A1;" FontSize="10" VerticalAlignment="Center" />
                    </Button>
                    <Button x:Name="CloseBtn" Width="40" Height="32" Padding="0"
                            VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource FgSecondary}">
                        <TextBlock Text="&#x2715;" FontSize="11" VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Layout region -->
        <regions:RegionControl Grid.Row="1" RegionId="MainWindow.Layout" />

        <!-- Row 2: Status bar region -->
        <regions:RegionControl Grid.Row="2" RegionId="MainWindow.StatusBar" />

    </Grid>
</Window>
