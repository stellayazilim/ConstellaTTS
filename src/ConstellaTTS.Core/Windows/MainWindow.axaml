<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
        x:Class="ConstellaTTS.Core.Windows.MainWindow"
        Title="ConstellaTTS"
        MinWidth="800" MinHeight="500">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Row 0: Ribbon -->
        <Border Grid.Row="0"
                Background="#1E1E1E"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,0,1">
            <Menu Background="Transparent">
                <MenuItem Header="File" />
                <MenuItem Header="Edit" />
                <MenuItem Header="View" />
                <MenuItem Header="Help" />
            </Menu>
        </Border>

        <!-- Row 1: Toolbar -->
        <Border Grid.Row="1"
                Background="#252525"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*">

                <!-- Transport controls -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="4"
                            Margin="8,4">
                    <Button ToolTip.Tip="Go to Start">&#x23EE;</Button>
                    <Button ToolTip.Tip="Play">&#x25B6;</Button>
                    <Button ToolTip.Tip="Stop">&#x23F9;</Button>
                </StackPanel>

                <!-- Divider -->
                <Border Grid.Column="1"
                        Width="1"
                        Margin="4,8"
                        Background="#3A3A3A" />

                <!-- Toolbar slot placeholder -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Margin="8,4"
                            Spacing="4"
                            x:Name="ToolbarSlot" />

            </Grid>
        </Border>

        <!-- Row 2: Logo + ViewTools -->
        <Border Grid.Row="2"
                Background="#222222"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="160,Auto,*">

                <!-- Logo -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8"
                            Margin="12,6">
                    <Border Width="26" Height="26"
                            CornerRadius="6"
                            Background="#2E2E2E"
                            BorderBrush="#3A3A3A"
                            BorderThickness="1" />
                    <TextBlock Text="ConstellaTTS"
                               VerticalAlignment="Center"
                               FontWeight="Medium"
                               Foreground="#CCCCCC" />
                </StackPanel>

                <!-- Divider -->
                <Border Grid.Column="1"
                        Width="1"
                        Margin="0,6"
                        Background="#3A3A3A" />

                <!-- ViewTools slot placeholder -->
                <ContentControl Grid.Column="2"
                                Margin="12,6"
                                x:Name="ViewToolsSlot" />

            </Grid>
        </Border>

        <!-- Row 3: Content slot -->
        <Border Grid.Row="3"
                Background="#181818">
            <ContentControl x:Name="ContentSlot" />
        </Border>

    </Grid>

</Window>
