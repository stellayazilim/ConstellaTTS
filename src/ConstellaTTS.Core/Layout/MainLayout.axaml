<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:ConstellaTTS.Core.Controls"
             xmlns:regions="clr-namespace:ConstellaTTS.Core.UI.Regions;assembly=ConstellaTTS.Core"
             x:Class="ConstellaTTS.Core.Layout.MainLayout">

    <Grid RowDefinitions="36,40,*">

        <!-- ── Row 0: Toolbar ── -->
        <Border Grid.Row="0" Classes="g-bg-toolbar g-border-subtle"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*">

                <!-- Fixed player controls -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="4"
                            Margin="8,4"
                            VerticalAlignment="Center">
                    <controls:PlayerButton Foreground="{StaticResource AccentPurple}"
                                           ToolTip.Tip="Go to Start">
                        <controls:GoToStartIcon />
                    </controls:PlayerButton>
                    <controls:PlayerButton Foreground="{StaticResource AccentBlue}"
                                           ToolTip.Tip="Play">
                        <controls:PlayIcon />
                    </controls:PlayerButton>
                    <controls:PlayerButton Foreground="{StaticResource AccentPink}"
                                           ToolTip.Tip="Stop">
                        <controls:StopIcon />
                    </controls:PlayerButton>
                </StackPanel>

                <Border Grid.Column="1" Classes="g-separator-v" Margin="4,8" />

                <!-- Toolbar region — plugins mount toolbar items here -->
                <regions:RegionControl Grid.Column="2"
                                       RegionId="MainWindow.Layout.Toolbar"
                                       Margin="8,0"
                                       VerticalAlignment="Center" />

            </Grid>
        </Border>

        <!-- ── Row 1: Logo + ViewTools region ── -->
        <Border Grid.Row="1"
                Background="{StaticResource BgLogoRow}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="200,1,*">

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8"
                            Margin="10,0"
                            VerticalAlignment="Center">
                    <Image Source="{SvgImage avares://ConstellaTTS.Core/Assets/logo.svg}"
                           Width="28" Height="28" />
                    <TextBlock FontFamily="{StaticResource FontBrand}"
                               FontSize="11"
                               FontWeight="Bold"
                               LetterSpacing="1.5"
                               VerticalAlignment="Center">
                        <TextBlock.Foreground>
                            <StaticResource ResourceKey="GradText" />
                        </TextBlock.Foreground>
                        ConstellaTTS
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource BorderMid}"
                        Margin="0,6" />

                <!-- ViewTools region -->
                <regions:RegionControl Grid.Column="2"
                                       RegionId="MainWindow.Layout.ViewTools"
                                       Margin="12,0"
                                       VerticalAlignment="Center" />

            </Grid>
        </Border>

        <!-- ── Row 2: Content region ── -->
        <Border Grid.Row="2"
                x:Name="TimelineRegion"
                Background="{StaticResource BgBase}">
            <regions:RegionControl RegionId="MainWindow.Layout.Content" />
        </Border>

    </Grid>

</UserControl>
