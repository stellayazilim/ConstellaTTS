<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ConstellaTTS.Core.Controls.TrackHeader">

    <Grid ColumnDefinitions="4,*" Height="52">

        <!-- Renkli şerit — renk DarkTheme selector'dan gelir -->
        <Border Grid.Column="0"
                x:Name="ColorBar" />

        <!-- İçerik -->
        <StackPanel Grid.Column="1"
                    Orientation="Vertical"
                    Margin="10,0,8,0"
                    Spacing="3"
                    VerticalAlignment="Center">

            <TextBlock x:Name="TrackNameBlock"
                       Text="Track"
                       FontWeight="Medium"
                       TextTrimming="CharacterEllipsis" />

            <TextBlock x:Name="TrackMetaBlock"
                       Text="" />

        </StackPanel>

    </Grid>

</UserControl>
