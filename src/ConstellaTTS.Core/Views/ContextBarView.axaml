<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConstellaTTS.Core.ViewModels"
             x:Class="ConstellaTTS.Core.Views.ContextBarView"
             x:DataType="vm:ContextBarViewModel">

    <!-- Tool-only contextual bar.
         Holds the primary tool radio (Select / Create), its sub-type
         radio (Section / Stage, surfaces only in Create mode), and a
         contextual Delete button that appears when Select has something
         picked. The trailing column absorbs slack so the toolbar reads
         left-aligned without a stretched final cell.

         Earlier this row also carried a "Giriş · 2 track · 0:32"
         section summary and a Ctrl/Scroll cheat-sheet hint string —
         both removed: the summary was per-section info that doesn't
         belong on a tool toolbar, and the hint string was unreadable
         at the muted opacity it needed to not steal attention.
         Documenting interaction belongs in tooltips / a help panel,
         not in chrome. -->
    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">

        <!-- Primary tool radio: Select / Create -->
        <Button Grid.Column="0"
                Classes="mode-btn"
                Classes.active="{Binding IsSelectTool}"
                Command="{Binding ActivateSelectCommand}"
                ToolTip.Tip="Select (V)">
            Select
        </Button>
        <Button Grid.Column="1"
                Classes="mode-btn"
                Classes.active="{Binding IsCreateTool}"
                Command="{Binding ActivateCreateCommand}"
                ToolTip.Tip="Create (B)">
            Create
        </Button>

        <!-- Sub-type radio divider — hidden in lockstep with the radio
             itself so Select mode doesn't show a hanging separator. -->
        <Border Grid.Column="2"
                Classes="g-separator-v"
                Margin="6,8"
                IsVisible="{Binding IsSubTypeVisible}" />

        <!-- Sub-type radio: Section / Stage. Only surfaces while Create
             is the active (or previewed) tool — in Select mode these
             buttons have no effect and would be misleading clutter. -->
        <Button Grid.Column="3"
                Classes="mode-btn"
                Classes.active="{Binding IsSection}"
                IsVisible="{Binding IsSubTypeVisible}"
                Command="{Binding SelectSectionCommand}"
                ToolTip.Tip="Section (Ctrl+drag)">
            Section
        </Button>
        <Button Grid.Column="4"
                Classes="mode-btn"
                Classes.active="{Binding IsStage}"
                IsVisible="{Binding IsSubTypeVisible}"
                Command="{Binding SelectStageCommand}"
                ToolTip.Tip="Stage (Ctrl+Shift+drag)">
            Stage
        </Button>

        <!-- Delete — Select mode + block/track selected. Separator and
             button fade in together so neighbouring buttons don't shift
             when the selection changes. -->
        <Border Grid.Column="5"
                Classes="g-separator-v"
                Margin="6,8"
                IsVisible="{Binding IsDeleteVisible}" />
        <Button Grid.Column="6"
                Classes="mode-btn"
                IsVisible="{Binding IsDeleteVisible}"
                Command="{Binding DeleteSelectionCommand}"
                ToolTip.Tip="Seçili bloğu / track'i sil (Del)"
                Foreground="{DynamicResource StatusDanger}">
            <TextBlock Text="{Binding DeleteLabel}" />
        </Button>

        <!-- Trailing slack column — soaks remaining width so buttons
             don't stretch. Empty by design. -->

    </Grid>

</UserControl>
