<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="32"
             x:Class="ConstellaTTS.Core.Views.TestToolbarView">

    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="8,0">

        <Border Classes="timecode">
            <TextBlock Text="00:00.0" />
        </Border>

        <Border Classes="g-separator-v" Margin="4,8" />

        <TextBlock Classes="toolbar-label" Margin="0,0,4,0" Text="Engine:" />
        <TextBlock FontSize="11"
                   FontWeight="Medium"
                   Foreground="{StaticResource FgPrimary}"
                   VerticalAlignment="Center"
                   Margin="0,0,6,0"
                   Text="Chatterbox ML" />
        <Border Classes="badge cyan" VerticalAlignment="Center">
            <TextBlock Text="lokal" />
        </Border>

        <Border Classes="g-separator-v" Margin="4,8" />

        <Button x:Name="SampleLibraryButton"
                Classes="mode-btn"
                ToolTip.Tip="Ses Bankası (Ctrl+L)">
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="🎵" FontSize="11" />
                <TextBlock Text="Ses Bankası" VerticalAlignment="Center" />
            </StackPanel>
        </Button>

    </StackPanel>

</UserControl>
