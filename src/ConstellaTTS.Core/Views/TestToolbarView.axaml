<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="32"
             x:Class="ConstellaTTS.Core.Views.TestToolbarView">

    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="8,0">
        <Border Width="6" Height="6" CornerRadius="3" Background="#7c6af7" />
        <TextBlock Text="TestToolbarView mounted ✓"
                   FontSize="11"
                   Foreground="#7c6af7"
                   VerticalAlignment="Center" />
    </StackPanel>

</UserControl>
