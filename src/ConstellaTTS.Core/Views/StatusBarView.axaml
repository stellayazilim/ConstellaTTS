<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConstellaTTS.Core.ViewModels"
             x:Class="ConstellaTTS.Core.Views.StatusBarView"
             x:DataType="vm:StatusBarViewModel">

    <Border Background="{DynamicResource BgRibbon}"
            BorderBrush="{DynamicResource BorderSubtle}"
            BorderThickness="0,1,0,0"
            Height="24">

        <Grid ColumnDefinitions="Auto,*">

            <!-- Sol: engine info -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="12"
                        Margin="12,0"
                        VerticalAlignment="Center">

                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Ellipse Width="7" Height="7"
                             Fill="{DynamicResource StatusSuccess}"
                             VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Engine}"
                               FontSize="10"
                               FontWeight="Medium"
                               Foreground="{DynamicResource FgPrimary}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Border Width="1" Background="{DynamicResource BorderSubtle}" Margin="0,4" />

                <TextBlock Text="{Binding Duration}"
                           FontSize="10"
                           Foreground="{DynamicResource FgMuted}"
                           VerticalAlignment="Center" />

                <TextBlock Text="{Binding BlockCount}"
                           FontSize="10"
                           Foreground="{DynamicResource FgMuted}"
                           VerticalAlignment="Center" />

                <TextBlock Text="{Binding Cache}"
                           FontSize="10"
                           Foreground="{DynamicResource FgMuted}"
                           VerticalAlignment="Center" />

            </StackPanel>

            <!-- Sağ: progress bar -->
            <Border Grid.Column="1"
                    Margin="16,5,16,5"
                    CornerRadius="2"
                    Background="{DynamicResource BgElevated}"
                    BorderBrush="{DynamicResource BorderSubtle}"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Panel>

                    <!-- Gradient fill — stub at ~60% -->
                    <Border HorizontalAlignment="Left"
                            Width="300"
                            CornerRadius="1"
                            Margin="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                <GradientStop Color="#337C6AF7" Offset="0" />
                                <GradientStop Color="#667C6AF7" Offset="0.6" />
                                <GradientStop Color="#9960AAFF" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Status label centered over bar -->
                    <TextBlock Text="{Binding StatusLabel}"
                               FontSize="9"
                               FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"
                               Foreground="{DynamicResource FgMuted}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               LetterSpacing="0.5"
                               Opacity="0.8" />

                </Panel>
            </Border>

        </Grid>
    </Border>

</UserControl>
