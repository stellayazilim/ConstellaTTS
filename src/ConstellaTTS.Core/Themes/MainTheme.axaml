<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Füme arka plan katmanları ── -->
    <SolidColorBrush x:Key="BgBase"       Color="#0D0D14" />  <!-- en koyu, content -->
    <SolidColorBrush x:Key="BgSurface"    Color="#13131E" />  <!-- panel, off-canvas -->
    <SolidColorBrush x:Key="BgElevated"   Color="#1A1A2A" />  <!-- kartlar -->
    <SolidColorBrush x:Key="BgToolbar"    Color="#16161F" />  <!-- toolbar -->
    <SolidColorBrush x:Key="BgRibbon"     Color="#111119" />  <!-- ribbon -->
    <SolidColorBrush x:Key="BgLogoRow"    Color="#14141E" />  <!-- logo row -->
    <SolidColorBrush x:Key="BgTrack"      Color="#18182A" />  <!-- timeline track -->
    <SolidColorBrush x:Key="BgTrackAlt"   Color="#15152A" />  <!-- timeline track alt -->
    <SolidColorBrush x:Key="BgSection"    Color="#1C1C2E" />  <!-- section item -->

    <!-- ── Kenarlıklar ── -->
    <SolidColorBrush x:Key="BorderSubtle"  Color="#252538" />
    <SolidColorBrush x:Key="BorderMid"     Color="#32324A" />
    <SolidColorBrush x:Key="BorderStrong"  Color="#44446A" />

    <!-- ── Neon mor gradient ── -->
    <LinearGradientBrush x:Key="NeonGradient" StartPoint="0%,0%" EndPoint="100%,0%">
        <GradientStop Color="#7c6af7" Offset="0" />
        <GradientStop Color="#d060ff" Offset="1" />
    </LinearGradientBrush>

    <!-- ── Section aksan renkleri ── -->
    <SolidColorBrush x:Key="AccentPurple"  Color="#7c6af7" />
    <SolidColorBrush x:Key="AccentBlue"    Color="#60aaff" />
    <SolidColorBrush x:Key="AccentPink"    Color="#d060ff" />
    <SolidColorBrush x:Key="AccentRose"    Color="#ff60a0" />
    <SolidColorBrush x:Key="AccentCyan"    Color="#50e0ff" />

    <!-- ── Track blok renkleri ── -->
    <SolidColorBrush x:Key="TrackNarrator"    Color="#2A2560" />
    <SolidColorBrush x:Key="TrackCharacterA"  Color="#1a3a5c" />
    <SolidColorBrush x:Key="TrackCharacterB"  Color="#3a1a5c" />

    <!-- ── Metin ── -->
    <SolidColorBrush x:Key="FgPrimary"    Color="#D0D0E8" />
    <SolidColorBrush x:Key="FgSecondary"  Color="#888899" />
    <SolidColorBrush x:Key="FgMuted"      Color="#444455" />
    <SolidColorBrush x:Key="FgDisabled"   Color="#2A2A3A" />

    <!-- ── Ruler / zaman işaretleri ── -->
    <SolidColorBrush x:Key="RulerText"    Color="#3A3A55" />
    <SolidColorBrush x:Key="RulerBg"      Color="#111119" />
    <!-- ── Pencere kontrol butonları ── -->
    <SolidColorBrush x:Key="WinBtnHover"      Color="#2A2A4A" />
    <SolidColorBrush x:Key="WinBtnCloseHover" Color="#C42B2B" />

</ResourceDictionary>
