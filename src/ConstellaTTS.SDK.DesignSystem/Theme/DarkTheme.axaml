<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         CONSTELLA — Dark Theme
    ════════════════════════════════════════════════════════════ -->

    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://ConstellaTTS.SDK.DesignSystem/Theme/DarkThemeResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Styles.Resources>


    <!-- ══════════════════════════════
         BACKGROUNDS
    ══════════════════════════════ -->

    <Style Selector="Window.g-bg-base">
        <Setter Property="Background" Value="{DynamicResource BgBase}" />
    </Style>
    <Style Selector="Border.g-bg-base">
        <Setter Property="Background" Value="{DynamicResource BgBase}" />
    </Style>
    <Style Selector="Panel.g-bg-base">
        <Setter Property="Background" Value="{DynamicResource BgBase}" />
    </Style>
    <Style Selector="Grid.g-bg-base">
        <Setter Property="Background" Value="{DynamicResource BgBase}" />
    </Style>
    <Style Selector="StackPanel.g-bg-base">
        <Setter Property="Background" Value="{DynamicResource BgBase}" />
    </Style>
    <Style Selector="Border.g-bg-elevated">
        <Setter Property="Background" Value="{DynamicResource BgElevated}" />
    </Style>
    <Style Selector="Panel.g-bg-elevated">
        <Setter Property="Background" Value="{DynamicResource BgElevated}" />
    </Style>
    <Style Selector="Grid.g-bg-elevated">
        <Setter Property="Background" Value="{DynamicResource BgElevated}" />
    </Style>
    <Style Selector="StackPanel.g-bg-elevated">
        <Setter Property="Background" Value="{DynamicResource BgElevated}" />
    </Style>
    <Style Selector="Border.g-bg-toolbar">
        <Setter Property="Background" Value="{DynamicResource BgToolbar}" />
    </Style>
    <Style Selector="Panel.g-bg-toolbar">
        <Setter Property="Background" Value="{DynamicResource BgToolbar}" />
    </Style>
    <Style Selector="Grid.g-bg-toolbar">
        <Setter Property="Background" Value="{DynamicResource BgToolbar}" />
    </Style>
    <Style Selector="Border.g-bg-ribbon">
        <Setter Property="Background" Value="{DynamicResource BgRibbon}" />
    </Style>
    <Style Selector="Panel.g-bg-ribbon">
        <Setter Property="Background" Value="{DynamicResource BgRibbon}" />
    </Style>
    <Style Selector="Grid.g-bg-ribbon">
        <Setter Property="Background" Value="{DynamicResource BgRibbon}" />
    </Style>
    <Style Selector="Border.g-bg-logo-row">
        <Setter Property="Background" Value="{DynamicResource BgLogoRow}" />
    </Style>
    <Style Selector="Grid.g-bg-logo-row">
        <Setter Property="Background" Value="{DynamicResource BgLogoRow}" />
    </Style>
    <Style Selector="Border.g-bg-track">
        <Setter Property="Background" Value="{DynamicResource BgTrack}" />
    </Style>
    <Style Selector="Panel.g-bg-track">
        <Setter Property="Background" Value="{DynamicResource BgTrack}" />
    </Style>
    <Style Selector="Grid.g-bg-track">
        <Setter Property="Background" Value="{DynamicResource BgTrack}" />
    </Style>
    <Style Selector="Border.g-bg-track-alt">
        <Setter Property="Background" Value="{DynamicResource BgTrackAlt}" />
    </Style>
    <Style Selector="Panel.g-bg-track-alt">
        <Setter Property="Background" Value="{DynamicResource BgTrackAlt}" />
    </Style>
    <Style Selector="Grid.g-bg-track-alt">
        <Setter Property="Background" Value="{DynamicResource BgTrackAlt}" />
    </Style>
    <Style Selector="Border.g-bg-section">
        <Setter Property="Background" Value="{DynamicResource BgSection}" />
    </Style>
    <Style Selector="Panel.g-bg-section">
        <Setter Property="Background" Value="{DynamicResource BgSection}" />
    </Style>
    <Style Selector="Grid.g-bg-section">
        <Setter Property="Background" Value="{DynamicResource BgSection}" />
    </Style>
    <Style Selector="Border.g-bg-ruler">
        <Setter Property="Background" Value="{DynamicResource RulerBg}" />
    </Style>
    <Style Selector="Grid.g-bg-ruler">
        <Setter Property="Background" Value="{DynamicResource RulerBg}" />
    </Style>


    <!-- ══════════════════════════════
         BORDERS
    ══════════════════════════════ -->

    <Style Selector="Border.g-border-subtle">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.g-border-mid">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderMid}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.g-border-strong">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.g-separator-h">
        <Setter Property="Background" Value="{DynamicResource BorderSubtle}" />
        <Setter Property="Height" Value="1" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.g-separator-v">
        <Setter Property="Background" Value="{DynamicResource BorderSubtle}" />
        <Setter Property="Width" Value="1" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>


    <!-- ══════════════════════════════
         FOREGROUND / TEXT
    ══════════════════════════════ -->

    <Style Selector="TextBlock.g-fg-primary">
        <Setter Property="Foreground" Value="{DynamicResource FgPrimary}" />
    </Style>
    <Style Selector="TextBlock.g-fg-secondary">
        <Setter Property="Foreground" Value="{DynamicResource FgSecondary}" />
    </Style>
    <Style Selector="TextBlock.g-fg-muted">
        <Setter Property="Foreground" Value="{DynamicResource FgMuted}" />
    </Style>
    <Style Selector="TextBlock.g-fg-ruler">
        <Setter Property="Foreground" Value="{DynamicResource RulerText}" />
    </Style>
    <Style Selector="TextBlock.g-fg-accent-purple">
        <Setter Property="Foreground" Value="{DynamicResource AccentPurple}" />
    </Style>
    <Style Selector="TextBlock.g-fg-accent-blue">
        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}" />
    </Style>
    <Style Selector="TextBlock.g-fg-accent-cyan">
        <Setter Property="Foreground" Value="{DynamicResource AccentCyan}" />
    </Style>
    <Style Selector="TextBlock.g-fg-accent-pink">
        <Setter Property="Foreground" Value="{DynamicResource AccentPink}" />
    </Style>
    <Style Selector="TextBlock.g-fg-accent-rose">
        <Setter Property="Foreground" Value="{DynamicResource AccentRose}" />
    </Style>
    <Style Selector="TextBlock.g-fg-success">
        <Setter Property="Foreground" Value="{DynamicResource StatusSuccess}" />
    </Style>
    <Style Selector="TextBlock.g-fg-warning">
        <Setter Property="Foreground" Value="{DynamicResource StatusWarning}" />
    </Style>
    <Style Selector="TextBlock.g-fg-danger">
        <Setter Property="Foreground" Value="{DynamicResource StatusDanger}" />
    </Style>


    <!-- ══════════════════════════════
         TYPOGRAPHY
    ══════════════════════════════ -->

    <Style Selector="TextBlock.g-text-xs">
        <Setter Property="FontSize" Value="10" />
    </Style>
    <Style Selector="TextBlock.g-text-sm">
        <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="TextBlock.g-text-md">
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="TextBlock.g-text-lg">
        <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="TextBlock.g-text-xl">
        <Setter Property="FontSize" Value="16" />
    </Style>


    <!-- ══════════════════════════════
         BUTTON — ctts
    ══════════════════════════════ -->

    <Style Selector="Button.ctts">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="DM Sans,Segoe UI,sans-serif" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.ctts.sm">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Padding" Value="10,4" />
    </Style>
    <Style Selector="Button.ctts.lg">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="18,8" />
    </Style>
    <Style Selector="Button.ctts.primary">
        <Setter Property="Background" Value="{DynamicResource AccentPurple}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentPurple}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource FgPrimary}" />
    </Style>
    <Style Selector="Button.ctts.primary:pointerover /template/ Border#PART_Root">
        <Setter Property="Background" Value="#8b7af9" />
    </Style>
    <Style Selector="Button.ctts.primary:pressed /template/ Border#PART_Root">
        <Setter Property="Background" Value="#6a58e0" />
        <Setter Property="RenderTransform"><ScaleTransform ScaleX="0.97" ScaleY="0.97" /></Setter>
    </Style>
    <Style Selector="Button.ctts.gradient">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource FgPrimary}" />
        <Setter Property="Background" Value="{DynamicResource GradientNeon}" />
    </Style>
    <Style Selector="Button.ctts.gradient:pressed /template/ Border#PART_Root">
        <Setter Property="RenderTransform"><ScaleTransform ScaleX="0.97" ScaleY="0.97" /></Setter>
    </Style>
    <Style Selector="Button.ctts.outline">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentPurple}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource AccentPurple}" />
    </Style>
    <Style Selector="Button.ctts.outline:pointerover /template/ Border#PART_Root">
        <Setter Property="Background" Value="{DynamicResource BorderSubtle}" />
    </Style>
    <Style Selector="Button.ctts.ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource FgSecondary}" />
    </Style>
    <Style Selector="Button.ctts.ghost:pointerover /template/ Border#PART_Root">
        <Setter Property="Background" Value="{DynamicResource BorderSubtle}" />
    </Style>
    <Style Selector="Button.ctts.ghost:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource FgPrimary}" />
    </Style>
    <Style Selector="Button.ctts.danger">
        <Setter Property="Background" Value="#1FF87171" />
        <Setter Property="BorderBrush" Value="{DynamicResource StatusDanger}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource StatusDanger}" />
    </Style>
    <Style Selector="Button.ctts.danger:pointerover /template/ Border#PART_Root">
        <Setter Property="Background" Value="#33F87171" />
    </Style>

    <!-- Accent: standard "go-ahead" affirmative button. The neon-violet
         glow signals "yes, do this" without the alarm-bell red of
         danger. Used for dialog confirms (Add Track "Ekle", Save, etc.)
         where the action is a normal commit, not destructive.

         Owns its own template (like mode-btn / section-item) for two
         reasons:
           1. Fluent's default Button template paints :isDefault buttons
              with the system accent (red on Windows by default), and
              that pseudo-class wins over a plain Background setter on
              the Button itself.
           2. BoxShadow attaches to the Border, not the Button — we want
              a soft violet halo as the emissive cue, and that has to
              live on a named element we control.

         The :isDefault selector is included so even if a future caller
         sets IsDefault="True" the system accent doesn't sneak back in. -->
    <Style Selector="Button.ctts.accent">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="DM Sans,Segoe UI,sans-serif" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border x:Name="AccentRoot"
                        Background="{DynamicResource AccentPurple}"
                        BorderBrush="#9b8aff"
                        BorderThickness="1"
                        CornerRadius="6"
                        BoxShadow="0 0 14 0 #807C6AF7"
                        Padding="{TemplateBinding Padding}">
                    <Border.Transitions>
                        <Transitions>
                            <BrushTransition  Property="Background" Duration="0:0:0.1" />
                            <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.15" />
                        </Transitions>
                    </Border.Transitions>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      Foreground="{TemplateBinding Foreground}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.ctts.accent:pointerover /template/ Border#AccentRoot">
        <Setter Property="Background" Value="#8b7af9" />
        <Setter Property="BoxShadow" Value="0 0 22 0 #B07C6AF7" />
    </Style>
    <Style Selector="Button.ctts.accent:pressed /template/ Border#AccentRoot">
        <Setter Property="Background" Value="#6a58e0" />
        <Setter Property="BoxShadow" Value="0 0 8 0 #607C6AF7" />
        <Setter Property="RenderTransform">
            <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
        </Setter>
    </Style>
    <!-- Defensive override: even if someone sets IsDefault="True" the
         visual stays accent-violet, not system-red. -->
    <Style Selector="Button.ctts.accent:isDefault /template/ Border#AccentRoot">
        <Setter Property="Background" Value="{DynamicResource AccentPurple}" />
    </Style>


    <!-- ══════════════════════════════
         MODE BUTTON
    ══════════════════════════════ -->

    <Style Selector="Button.mode-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource FgSecondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderMid}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="9,3" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontFamily" Value="DM Sans,Segoe UI,sans-serif" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border x:Name="Root"
                        Background="Transparent"
                        BorderBrush="{DynamicResource BorderMid}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="9,3">
                    <Border.Transitions>
                        <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.1" />
                            <BrushTransition Property="BorderBrush" Duration="0:0:0.1" />
                        </Transitions>
                    </Border.Transitions>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      Foreground="{TemplateBinding Foreground}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.mode-btn:pointerover /template/ Border#Root">
        <Setter Property="Background" Value="{DynamicResource BgElevated}" />
    </Style>
    <Style Selector="Button.mode-btn:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource FgPrimary}" />
    </Style>
    <Style Selector="Button.mode-btn.active">
        <Setter Property="Background" Value="#1A7C6AF7" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentPurple}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentPurple}" />
    </Style>
    <Style Selector="Button.mode-btn.active:pointerover /template/ Border#Root">
        <Setter Property="Background" Value="#267C6AF7" />
    </Style>
    <Style Selector="Button.mode-btn.active:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource AccentPurple}" />
    </Style>


    <!-- ══════════════════════════════
         SECTION ITEM
    ══════════════════════════════ -->

    <Style Selector="Button.section-item">
        <Setter Property="Height" Value="56" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="{DynamicResource BgSection}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border x:Name="Root"
                        Background="{DynamicResource BgSection}"
                        BorderBrush="{DynamicResource BorderSubtle}"
                        BorderThickness="0,0,0,1">
                    <Border.Transitions>
                        <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.1" />
                        </Transitions>
                    </Border.Transitions>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.section-item:pointerover /template/ Border#Root">
        <Setter Property="Background" Value="{DynamicResource BgElevated}" />
    </Style>
    <Style Selector="Button.section-item.active /template/ Border#Root">
        <Setter Property="Background" Value="#0D7C6AF7" />
    </Style>


    <!-- ══════════════════════════════
         TOOLBAR CHROME
    ══════════════════════════════ -->

    <Style Selector="Border.toolbar-strip">
        <Setter Property="Background" Value="{DynamicResource BgToolbar}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Height" Value="36" />
    </Style>
    <Style Selector="Border.toolbar-divider">
        <Setter Property="Width" Value="1" />
        <Setter Property="Background" Value="{DynamicResource BorderMid}" />
        <Setter Property="Margin" Value="4,8" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="TextBlock.toolbar-label">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource FgMuted}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>


    <!-- ══════════════════════════════
         INPUT — ctts
    ══════════════════════════════ -->

    <Style Selector="TextBox.ctts">
        <Setter Property="Background" Value="{DynamicResource BgElevated}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderMid}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Foreground" Value="{DynamicResource FgPrimary}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AccentPurple}" />
        <Setter Property="FontFamily" Value="DM Sans,Segoe UI,sans-serif" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="SelectionBrush" Value="{DynamicResource BorderSubtle}" />
    </Style>
    <Style Selector="TextBox.ctts:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentPurple}" />
    </Style>
    <Style Selector="TextBox.ctts /template/ TextBlock#PART_Watermark">
        <Setter Property="Foreground" Value="{DynamicResource FgMuted}" />
    </Style>
    <Style Selector="TextBox.ctts.mono">
        <Setter Property="FontFamily" Value="JetBrains Mono,Cascadia Code,Consolas,monospace" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Padding" Value="10,5" />
    </Style>

    <!-- Global TextBox focus override.
         Applies to every TextBox — with or without the .ctts class —
         so dialogs that just drop in <TextBox> (rename inline, Add Track
         dialog, etc.) get the neon-violet ring instead of Avalonia's
         default reddish system accent. The default focus colour reads
         as "validation error" in our dark palette; this swaps it for
         the brand colour so focus is unambiguously "this is active",
         not "this is wrong".

         The selectors below cover the three places Avalonia paints the
         focus chrome:
           1. The control itself (BorderBrush) on :focus / :focus-within.
           2. PART_BorderElement inside the default template (this is
              the actual rendered border on Fluent's TextBox; setting it
              on the control alone leaves the inner element untouched).
           3. The PART_BorderElement's :focus / :pointerover transitions
              so hover and focus both stay on-brand.

         All four point at AccentPurple so they read as one decision. -->
    <Style Selector="TextBox">
        <Setter Property="CaretBrush" Value="{DynamicResource AccentPurple}" />
        <Setter Property="SelectionBrush" Value="#557C6AF7" />
        <Setter Property="SelectionForegroundBrush" Value="{DynamicResource FgPrimary}" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentPurple}" />
    </Style>
    <Style Selector="TextBox:focus-within /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentPurple}" />
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="#9b8aff" />
    </Style>


    <!-- ══════════════════════════════
         TIMECODE
    ══════════════════════════════ -->

    <Style Selector="Border.timecode">
        <Setter Property="Background" Value="{DynamicResource BgElevated}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderMid}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style Selector="Border.timecode TextBlock">
        <Setter Property="FontFamily" Value="JetBrains Mono,Cascadia Code,Consolas,monospace" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource FgPrimary}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>


    <!-- ══════════════════════════════
         BADGE
    ══════════════════════════════ -->

    <Style Selector="Border.badge">
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Padding" Value="6,2" />
    </Style>
    <Style Selector="Border.badge TextBlock">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LetterSpacing" Value="0.5" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.badge.cyan">
        <Setter Property="Background" Value="#1A00CFCF" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentCyan}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.badge.cyan TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AccentCyan}" />
    </Style>

</Styles>
