<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ConstellaTTS.Avalonia.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://ConstellaTTS.SDK.DesignSystem/Theme/Tokens.axaml" />
                <ResourceInclude Source="avares://ConstellaTTS.SDK.DesignSystem/Theme/MainTheme.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://ConstellaTTS.SDK.DesignSystem/Theme/DarkTheme.axaml" />
        <StyleInclude Source="avares://ConstellaTTS.Core/Controls/ControlStyles.axaml" />

        <!-- Window control button overrides -->
        <Style Selector="Button#MinimizeBtn:pointerover, Button#MaximizeBtn:pointerover">
            <Setter Property="Background" Value="#2A2A4A" />
        </Style>
        <Style Selector="Button#CloseBtn:pointerover">
            <Setter Property="Background" Value="#C42B2B" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
    </Application.Styles>

</Application>
