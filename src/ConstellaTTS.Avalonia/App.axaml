<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ConstellaTTS.Avalonia.App"
             RequestedThemeVariant="Dark">

    <!-- ═══════════════════════════════════════════════════════════════
         App.axaml hosts only app-wide foundations:

           • Tokens      — palette atoms (Noir, Violet, …).
           • MainTheme   — ThemeDictionaries wrapper; Avalonia picks the
                           right inner dictionary automatically based on
                           RequestedThemeVariant (Dark / Light). Brings
                           semantic aliases in for free.
           • FluentTheme — fallback base styling for any control that
                           isn't overridden by our design system.

         Module-specific resources (ConstellaTTS design-system styles,
         Core control styles, window chrome, …) are registered at
         runtime via IThemeProvider.RegisterGlobal(...) by the owning
         module — see ConstellaTTSCoreModule.Build for the reference
         pattern.
    ═══════════════════════════════════════════════════════════════ -->

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://ConstellaTTS.SDK.DesignSystem/Theme/Tokens.axaml" />
                <ResourceInclude Source="avares://ConstellaTTS.SDK.DesignSystem/Theme/MainTheme.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://ConstellaTTS.SDK.DesignSystem/Theme/DarkTheme.axaml"></StyleInclude>
    </Application.Styles>

</Application>
